# ============================================
# LeadPulse — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================

# Banco de dados PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/leadpulse

# Redis (cache-aside do Kanban)
REDIS_URL=redis://redis:6379/0

# Groq API Key (IA) — obtenha em https://console.groq.com/keys
GROQ_API_KEY=

# Chave Fernet para cifrar credenciais dos canais
# CRITICAL: gere uma chave com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Segredo do webhook Z-API (cole na query-string do callback configurado no painel da Z-API)
ZAPI_WEBHOOK_SECRET=troque-este-valor-em-producao

# Intervalo de polling do IMAP (Gmail) em segundos
IMAP_POLL_INTERVAL_SECONDS=60

# Desabilita workers em background (útil para rodar testes ou migrations isoladas)
DISABLE_BACKGROUND_WORKERS=false
