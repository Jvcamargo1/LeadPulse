# ============================================
# LeadPulse — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================

# Ambiente — em "production" várias chaves são obrigatórias
ENVIRONMENT=development

# Banco de dados PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/leadpulse

# Redis (cache-aside do Kanban)
REDIS_URL=redis://redis:6379/0

# Groq API Key (IA) — obtenha em https://console.groq.com/keys
GROQ_API_KEY=

# Chave Fernet para cifrar credenciais dos canais
# CRITICAL: gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Chave para assinar JWT
# CRITICAL: gere com:
#   openssl rand -hex 32
SECRET_KEY=

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cache
CACHE_TTL_KANBAN_SECONDS=60

# Segredo do webhook Z-API (na query-string do callback)
ZAPI_WEBHOOK_SECRET=troque-este-valor-em-producao

# Worker IMAP
IMAP_POLL_INTERVAL_SECONDS=60
DISABLE_BACKGROUND_WORKERS=false
